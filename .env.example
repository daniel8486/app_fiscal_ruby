# Arquivo de configuração principal
DATABASE_URL=postgresql://user:password@localhost:5432/fiscal_system
REDIS_URL=redis://localhost:6379/0

# Configurações dos serviços
ORCHESTRATOR_PORT=4000
NFE_SERVICE_PORT=4001
NFCE_SERVICE_PORT=4002
NFSE_SERVICE_PORT=4003
CTE_SERVICE_PORT=4004
MDFE_SERVICE_PORT=4005
SAT_SERVICE_PORT=4006

# URLs dos serviços
NFE_SERVICE_URL=http://localhost:4001
NFCE_SERVICE_URL=http://localhost:4002
NFSE_SERVICE_URL=http://localhost:4003
CTE_SERVICE_URL=http://localhost:4004
MDFE_SERVICE_URL=http://localhost:4005
SAT_SERVICE_URL=http://localhost:4006

# Configurações de ambiente
ENVIRONMENT=development
LOG_LEVEL=debug

# Configurações de segurança
API_SECRET_KEY=your_secret_key_here
JWT_SECRET=your_jwt_secret_here

# Configurações SEFAZ (exemplo)
SEFAZ_ENVIRONMENT=homologacao
SEFAZ_CERTIFICATE_PATH=./certificates/
SEFAZ_CERTIFICATE_PASSWORD=certificate_password

# Timeouts
HTTP_TIMEOUT=30
SERVICE_TIMEOUT=60
